{
  "name": "@enthus/cli-tools",
  "version": "1.0.0",
  "description": "CLI tools setup for Enthus developers - sqlcmd, GitHub CLI, Atlassian CLI with LLM configuration",
  "type": "module",
  "bin": {
    "enthus-cli-setup": "./bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
