{
  "name": "@enthus-appdev/llm-cli-setup",
  "version": "1.1.2",
  "description": "CLI tools setup with LLM integration - installs and configures sqlcmd, gh, atl, n8nctl, grafanactl, logcli, m365, esq, and discordctl with Claude Code, Gemini CLI, and Codex support",
  "type": "module",
  "main": "./lib/index.js",
  "exports": {
    ".": "./lib/index.js",
    "./installers": "./lib/installers/index.js",
    "./llm": "./lib/llm/index.js",
    "./utils": "./lib/utils/index.js"
  },
  "bin": {
    "llm-cli-setup": "./bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check-format": "prettier --check ."
  },
  "author": "enthus GmbH",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "bin",
    "lib"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/enthus-appdev/llm-cli-setup.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "inquirer": "^13.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1"
  }
}
